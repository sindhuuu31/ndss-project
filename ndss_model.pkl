import pandas as pd
from sklearn.ensemble import RandomForestClassifier
import pickle
import random

# Generate dummy dataset
data = []

for _ in range(1000):
    packet_count = random.randint(100, 20000)
    packet_size = random.randint(64, 1500)
    entropy = round(random.uniform(0.1, 8.0), 2)

    # Label logic (simple)
    if packet_count > 5000 and entropy < 3:
        label = 1  # attack
    else:
        label = 0  # normal

    data.append([packet_count, packet_size, entropy, label])

df = pd.DataFrame(data, columns=["packet_count", "packet_size", "entropy", "label"])

X = df[["packet_count", "packet_size", "entropy"]]
y = df["label"]

# Train model
model = RandomForestClassifier()
model.fit(X, y)

# Save model
with open("ndss_model.pkl", "wb") as f:
    pickle.dump(model, f)

print("Model created successfully!")
